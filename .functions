# ==============================================================================
# Anobisoft Terminal Utility Functions
# ==============================================================================

# === Highlighting STDERR in Red ===
# Wraps any command, flips descriptors, and paints errors to bright red
function hlstderr() {
    # Включаем pipefail внутри функции, не ломая глобальные настройки шелла
    setopt localoptions pipefail
    
    # Карусель дескрипторов: STDERR уходит в пайп, STDOUT выплескивается на экран
    eval "$@" 3>&1 1>&2 2>&3 3>&2 | while read -r line
    do
        # Zsh-модификатор: срезает префиксы ошибок "filename: line XX:"
        local clean_line="${line##*:[0-9]#: }"
        
        # Печатаем строку в терминал, покрасив её в красный цвет через быстрый промпт-движок %F
        print -P "%F{red}${clean_line}%f"
    done
}
