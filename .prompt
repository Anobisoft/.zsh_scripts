# Переключаем zsh в режим динамического вычисления переменных в промпте
setopt PROMPT_SUBST

# Инициализация SSH (выполняется строго один раз при старте шелла)
if [ -n "$SSH_CONNECTION" ]; then
    SSH_HOST='%F{087}%n%f@%F{cyan}%m '
else
    SSH_HOST=''
fi

# Настройка отображения Git (ваши цвета, ветка уйдёт направо)
ZSH_THEME_GIT_PROMPT_PREFIX="%{$fg[blue]%}git%{$reset_color%}:%{$fg[green]%}"
ZSH_THEME_GIT_PROMPT_SUFFIX="%{$reset_color%}"
ZSH_THEME_GIT_PROMPT_DIRTY="%{$fg[yellow]%}*%{$reset_color%}"
ZSH_THEME_GIT_PROMPT_CLEAN=""

# ЛЕВЫЙ ПРОМПТ: ваши цвета, дата, точное время %T и знак %# (без инфо о Git)
PROMPT='$SSH_HOST%F{green}%D{%Y-%m-%d} %F{084}%T %F{blue}%1~ %F{red}%#%f '

# ПРАВЫЙ ПРОМПТ: информация о ветке Git теперь живет здесь
RPROMPT="$(git_prompt_info)"
