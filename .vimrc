syntax on
set tabstop=4 shiftwidth=4 expandtab smarttab
set nocompatible
set backspace=indent,eol,start
set ai

set number          " Включает нумерацию строк (легко перемещаться по коду и конфигам)
set mouse=a         " Разрешает использовать мышь (можно кликать курсором и скроллить колесиком)
set hlsearch        " Подсвечивает совпадения при поиске через '/'
set incsearch       " Ищет текст на лету, прямо во время ввода букв
set ignorecase      " Игнорировать регистр при поиске...
set smartcase       " ...но учитывать его, если в запросе есть заглавная буква
set wildmenu        " Включает удобное графическое автодополнение команд внизу экрана
set ruler           " Показывает текущую строку и колонку в правом нижнем углу
